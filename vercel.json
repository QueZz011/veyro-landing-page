{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/kocaeli-cekici.html",
      "destination": "/kocaeli/cekici",
      "permanent": true
    },
    {
      "source": "/istanbul-cekici.html",
      "destination": "/istanbul/cekici",
      "permanent": true
    },
    {
      "source": "/sehirler/kocaeli-cekici.html",
      "destination": "/kocaeli/cekici",
      "permanent": true
    },
    {
      "source": "/sehirler/istanbul-cekici.html",
      "destination": "/istanbul/cekici",
      "permanent": true
    },
    {
      "source": "/yol-yardim-rehberi.html",
      "destination": "/yol-yardim-rehberi",
      "permanent": true
    },
    {
      "source": "/blog/yol-yardim-rehberi.html",
      "destination": "/yol-yardim-rehberi",
      "permanent": true
    },
    {
      "source": "/yolda-kalinca-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/yolda-kalinca-ilk-ne-yapilmali",
      "permanent": true
    },
    {
      "source": "/blog/yolda-kalinca-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/yolda-kalinca-ilk-ne-yapilmali",
      "permanent": true
    },
    {
      "source": "/cekici-fiyatlari.html",
      "destination": "/yol-yardim-rehberi/cekici-fiyatlari-2026",
      "permanent": true
    },
    {
      "source": "/blog/cekici-fiyatlari.html",
      "destination": "/yol-yardim-rehberi/cekici-fiyatlari-2026",
      "permanent": true
    },
    {
      "source": "/aku-biterse-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/aku-bitince-ne-yapilir",
      "permanent": true
    },
    {
      "source": "/blog/aku-biterse-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/aku-bitince-ne-yapilir",
      "permanent": true
    },
    {
      "source": "/lastik-patlarsa-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/lastik-patlarsa-ne-yapilmali",
      "permanent": true
    },
    {
      "source": "/blog/lastik-patlarsa-ne-yapilmali.html",
      "destination": "/yol-yardim-rehberi/lastik-patlarsa-ne-yapilmali",
      "permanent": true
    },
    {
      "source": "/gizlilik.html",
      "destination": "/gizlilik-politikasi",
      "permanent": true
    },
    {
      "source": "/yasal/gizlilik.html",
      "destination": "/gizlilik-politikasi",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap-main.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ]
}
