{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/kocaeli-cekici.html",
      "destination": "/sehirler/kocaeli-cekici.html",
      "permanent": true
    },
    {
      "source": "/istanbul-cekici.html",
      "destination": "/sehirler/istanbul-cekici.html",
      "permanent": true
    },
    {
      "source": "/yol-yardim-rehberi.html",
      "destination": "/blog/yol-yardim-rehberi.html",
      "permanent": true
    },
    {
      "source": "/yolda-kalinca-ne-yapilmali.html",
      "destination": "/blog/yolda-kalinca-ne-yapilmali.html",
      "permanent": true
    },
    {
      "source": "/cekici-fiyatlari.html",
      "destination": "/blog/cekici-fiyatlari.html",
      "permanent": true
    },
    {
      "source": "/aku-biterse-ne-yapilmali.html",
      "destination": "/blog/aku-biterse-ne-yapilmali.html",
      "permanent": true
    },
    {
      "source": "/lastik-patlarsa-ne-yapilmali.html",
      "destination": "/blog/lastik-patlarsa-ne-yapilmali.html",
      "permanent": true
    },
    {
      "source": "/gizlilik.html",
      "destination": "/yasal/gizlilik.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap-main.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ]
}
